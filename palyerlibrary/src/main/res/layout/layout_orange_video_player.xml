<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- 播放器渲染层 -->
    <RelativeLayout
        android:id="@+id/surface_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center" />

    <!-- 封面图 -->
    <ImageView
        android:id="@+id/thumb"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:visibility="visible" />

    <!-- 加载中 -->
    <include
        android:id="@+id/loading"
        layout="@layout/layout_orange_loading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:visibility="gone" />

    <!-- 顶部控制栏 -->
    <include
        android:id="@+id/layout_top"
        layout="@layout/layout_orange_video_top"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true" />

    <!-- 底部控制栏 -->
    <include
        android:id="@+id/layout_bottom"
        layout="@layout/layout_orange_video_bottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true" />

    <!-- 中间播放按钮 -->
    <ImageView
        android:id="@+id/start"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_centerInParent="true"
        android:background="@drawable/dkplayer_shape_play_bg"
        android:padding="16dp"
        android:scaleType="centerInside"
        android:src="@drawable/dkplayer_ic_action_play_arrow" />

    <!-- 锁屏按钮 -->
    <ImageView
        android:id="@+id/lock_screen"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_centerVertical="true"
        android:layout_marginStart="16dp"
        android:padding="8dp"
        android:scaleType="centerInside"
        android:src="@drawable/dkplayer_selector_lock_button"
        android:visibility="gone" />

</RelativeLayout>
