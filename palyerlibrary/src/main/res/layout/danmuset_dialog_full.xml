<?xml version="1.0" encoding="UTF-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#00000000"
    android:id="@+id/layout">

    <!-- 内容区域 - 右侧对齐 -->
    <LinearLayout 
        android:layout_width="match_parent" 
        android:layout_height="match_parent" 
        android:layout_gravity="end"
        android:orientation="vertical" 
        android:gravity="center_vertical|right" 
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:paddingEnd="48dp"
        android:background="#00000000"
        android:id="@+id/content_layout">

        <LinearLayout 
            android:layout_width="wrap_content" 
            android:layout_height="wrap_content" 
            android:gravity="center_vertical" 
            android:orientation="vertical" 
            android:layout_margin="10dp" 
            android:padding="15dp" 
            android:minWidth="200dp" 
            android:background="@drawable/round" 
            android:id="@+id/shik">
            
            <ScrollView 
                android:id="@+id/gd1" 
                android:layout_width="match_parent" 
                android:layout_height="wrap_content"
                android:maxHeight="300dp"
                android:scrollbars="none">
                
                <LinearLayout 
                    android:id="@+id/ai_setting" 
                    android:layout_width="match_parent" 
                    android:layout_height="wrap_content" 
                    android:orientation="vertical">

                    <!-- 弹幕设置标题 -->
                    <TextView 
                        android:layout_width="match_parent" 
                        android:layout_height="wrap_content" 
                        android:text="弹幕设置" 
                        android:textColor="#ffe8e7e6" 
                        android:layout_marginBottom="5dp" 
                        android:textSize="16sp" 
                        android:background="#2af8f8f8" 
                        android:gravity="center"/>

                    <!-- 弹幕文字大小设置 -->
                    <TextView 
                        android:id="@+id/ai_size" 
                        android:layout_width="match_parent" 
                        android:layout_height="wrap_content" 
                        android:text="弹幕文字大小" 
                        android:textSize="12sp" 
                        android:layout_marginBottom="8dp" 
                        android:textColor="#ffe8e7e6" 
                        android:layout_marginTop="15dp" 
                        android:gravity="center"/>

                    <SeekBar 
                        android:id="@+id/ai_sizebar" 
                        android:layout_width="match_parent" 
                        android:layout_height="wrap_content" 
                        android:max="100" 
                        android:progress="50" 
                        android:minHeight="7dp" 
                        android:maxHeight="10dp" 
                        android:layout_margin="5dp" 
                        android:progressDrawable="@drawable/seekbar_progress" 
                        android:thumb="@drawable/dkplayer_seekbar_thumb" 
                        android:thumbOffset="0dp"/>

                    <!-- 弹幕速度设置 -->
                    <TextView 
                        android:id="@+id/ai_speed" 
                        android:layout_width="match_parent" 
                        android:layout_height="wrap_content" 
                        android:text="弹幕播放速度" 
                        android:textSize="12sp" 
                        android:layout_marginTop="16dp" 
                        android:layout_marginBottom="8dp" 
                        android:textColor="#ffe8e7e6" 
                        android:gravity="center"/>

                    <SeekBar 
                        android:id="@+id/ai_speedbar" 
                        android:layout_width="match_parent" 
                        android:layout_height="wrap_content" 
                        android:max="100" 
                        android:progress="50" 
                        android:minHeight="7dp" 
                        android:maxHeight="10dp" 
                        android:layout_margin="5dp" 
                        android:progressDrawable="@drawable/seekbar_progress" 
                        android:thumb="@drawable/dkplayer_seekbar_thumb" 
                        android:thumbOffset="0dp"/>

                    <!-- 弹幕透明度设置 -->
                    <TextView 
                        android:id="@+id/ai_alpha" 
                        android:layout_width="match_parent" 
                        android:layout_height="wrap_content" 
                        android:text="弹幕透明度" 
                        android:textSize="12sp" 
                        android:layout_marginTop="16dp" 
                        android:layout_marginBottom="8dp" 
                        android:textColor="#ffe8e7e6" 
                        android:gravity="center"/>

                    <SeekBar 
                        android:id="@+id/ai_alphabar" 
                        android:layout_width="match_parent" 
                        android:layout_height="wrap_content" 
                        android:max="100" 
                        android:progress="100" 
                        android:minHeight="7dp" 
                        android:maxHeight="10dp" 
                        android:layout_margin="5dp" 
                        android:progressDrawable="@drawable/seekbar_progress" 
                        android:thumb="@drawable/dkplayer_seekbar_thumb" 
                        android:thumbOffset="0dp"/>

                </LinearLayout>
            </ScrollView>
        </LinearLayout>

    </LinearLayout>
</FrameLayout>
