<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    android:background="@drawable/dialog_bg"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- 标题 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="OCR 翻译设置"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <!-- 说明 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="识别视频画面中的硬字幕，翻译成目标语言后显示"
        android:textColor="#AAAAAA"
        android:textSize="12sp"
        android:layout_marginBottom="16dp" />

    <!-- 源语言 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="字幕语言（源语言）"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:layout_marginBottom="8dp" />

    <Spinner
        android:id="@+id/spinner_source_lang"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="@drawable/spinner_bg"
        android:padding="8dp"
        android:layout_marginBottom="16dp" />

    <!-- 目标语言 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="翻译语言（目标语言）"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:layout_marginBottom="8dp" />

    <Spinner
        android:id="@+id/spinner_target_lang"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="@drawable/spinner_bg"
        android:padding="8dp"
        android:layout_marginBottom="20dp" />

    <!-- 按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <Button
            android:id="@+id/btn_cancel"
            android:layout_width="80dp"
            android:layout_height="36dp"
            android:text="取消"
            android:textColor="#AAAAAA"
            android:textSize="14sp"
            android:background="@android:color/transparent"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btn_start_ocr"
            android:layout_width="120dp"
            android:layout_height="36dp"
            android:text="开始识别"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:background="@drawable/btn_primary_bg" />
    </LinearLayout>
</LinearLayout>
